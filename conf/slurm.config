/*
 * SLURM executor configuration
 */

executor {
    name            = 'slurm'
    queueSize       = 100
    submitRateLimit = '10/1min'
    pollInterval    = '30 sec'
    exitReadTimeout = '10 min'
}

process {
    executor = 'slurm'
    queue    = 'main'

    // Adjust queue for long-running or high-memory tasks
    withLabel: 'process_high' {
        queue = 'main'
    }
    withLabel: 'process_long' {
        queue = 'main'
    }
}

// Limit resources to what the cluster allows
params {
    max_cpus   = 32
    max_memory = '128.GB'
    max_time   = '72.h'
}
