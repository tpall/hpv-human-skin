/*
 * Base configuration - default resource allocations
 */

process {
    cpus   = { 1 * task.attempt }
    memory = { 4.GB * task.attempt }
    time   = { 2.h * task.attempt }

    errorStrategy = { task.exitStatus in [140, 137, 104, 134, 139, 143] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // No default publishDir: each module declares its own. A catch-all default
    // here would silently publish raw outputs (e.g. SRA_DOWNLOAD's FASTQs) for
    // any process missing an explicit override — that footgun cost ~9 TB once.
}
