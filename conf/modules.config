/*
 * Per-module resource configuration
 */

process {
    withName: 'SRA_DOWNLOAD' {
        cpus   = 4
        memory = 4.GB
        time   = 6.h
        maxRetries = 3
        errorStrategy = { task.exitStatus in [137, 140, 143] ? 'retry' : (task.attempt <= 3 ? 'retry' : 'ignore') }
    }

    withName: 'FASTP' {
        cpus   = 4
        memory = 8.GB
        time   = 2.h
    }

    withName: 'KRAKEN2_SCREEN' {
        cpus   = 8
        memory = 32.GB
        time   = 2.h
    }

    withName: 'STAR_ALIGN' {
        cpus   = 8
        memory = 16.GB
        time   = 4.h
    }

    withName: 'HPV_TYPING' {
        cpus   = 2
        memory = 4.GB
        time   = 1.h
    }

    withName: 'TRANSCRIPT_CLASSIFY' {
        cpus   = 2
        memory = 4.GB
        time   = 1.h
    }

    withName: 'REPORT' {
        cpus   = 2
        memory = 8.GB
        time   = 1.h
    }
}
