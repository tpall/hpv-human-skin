/*
 * Per-module resource configuration
 */

process {
    // Batch per-sample processes into SLURM job arrays of size params.array_size
    // (see nextflow.config). Keep SRA_DISCOVERY and REPORT outside — they're
    // single-task and arrays would just add overhead.
    withName: '(SRA_DOWNLOAD|FASTP|KRAKEN2_SCREEN|STAR_ALIGN|HPV_TYPING|TRANSCRIPT_CLASSIFY)' {
        array = params.array_size
    }

    // Fail-soft on the per-sample steps up to and including the HPV screen:
    // one bad SRR (withdrawn, network glitch, etc.) must not sink the whole
    // chunk — drop it and keep going. STAR_ALIGN and later steps still
    // inherit the base `finish` policy.
    withName: 'SRA_DOWNLOAD' {
        cpus   = 4
        memory = 4.GB
        time   = 6.h
        maxRetries = 3
        errorStrategy = { task.attempt <= 3 ? 'retry' : 'ignore' }
    }

    withName: 'FASTP' {
        cpus   = 4
        memory = 8.GB
        time   = 2.h
        maxRetries = 2
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
    }

    withName: 'KRAKEN2_SCREEN' {
        cpus   = 8
        memory = 32.GB
        time   = 2.h
        maxRetries = 2
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
    }

    withName: 'STAR_ALIGN' {
        cpus   = 8
        memory = 16.GB
        time   = 4.h
    }

    withName: 'HPV_TYPING' {
        cpus   = 2
        memory = 4.GB
        time   = 1.h
    }

    withName: 'TRANSCRIPT_CLASSIFY' {
        cpus   = 2
        memory = 4.GB
        time   = 1.h
    }

    withName: 'REPORT' {
        cpus   = 2
        memory = 8.GB
        time   = 1.h
    }
}
