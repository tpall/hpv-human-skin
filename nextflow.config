/*
 * HPV in Human Skin - Nextflow Pipeline Configuration
 *
 * Identifies HPV types and their prevalence across human tissues
 * using public RNA-seq data from NCBI GEO/SRA.
 */

// Pipeline parameters
params {
    // --- Data discovery ---
    sra_query_terms   = "skin RNA-seq Homo sapiens"
    samplesheet       = null   // Pre-built samplesheet CSV (skip discovery if provided)
    max_samples       = 0      // 0 = no limit

    // --- HPV references ---
    hpv_ref_dir       = "${projectDir}/assets/hpv_references"
    hpv_gene_gff      = "${projectDir}/assets/hpv_references/hpv_gene_annotations.gff"
    kraken2_db        = "${projectDir}/assets/kraken2_db"

    // --- HPV detection thresholds ---
    hpv_min_reads     = 10     // Minimum Kraken2-classified HPV reads for HPV+ call
    hpv_min_coverage  = 0.10   // Minimum coverage breadth (fraction) for type assignment
    hpv_min_depth     = 2      // Minimum mean depth for type assignment
    late_transcript_min_reads = 3  // Min reads on L1/L2 to flag productive infection

    // --- QC ---
    fastp_min_quality = 20
    fastp_min_length  = 36

    // --- Tissue classification ---
    tissue_categories = "${projectDir}/assets/tissue_categories.csv"

    // --- Output ---
    outdir            = "${launchDir}/results"
    publish_dir_mode  = 'copy'

    // --- Chunked-execution flags (driven by bin/run_chunked.sh) ---
    // When true, the per-chunk run produces summary TSVs but skips the
    // final HTML REPORT — the driver runs REPORT once over aggregated data.
    skip_report       = false
    // Directory of aggregated per-chunk TSVs consumed by the REPORT_ONLY
    // entry workflow at the end of a chunked run.
    agg_dir           = null

    // --- Resource defaults ---
    max_cpus          = 16
    max_memory        = '64.GB'
    max_time          = '48.h'

    // --- SLURM array batching ---
    // Per-sample processes are grouped into SLURM job arrays of this size to
    // cut scheduler overhead at scale. Set to 0 to disable and submit each
    // task individually. Each array task still runs on its own node with its
    // own cpu/memory allocation — only the submission is batched.
    array_size        = 20
}

// Load base and module configs
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// Execution profiles
// Each process defines its own conda env and container image.
// Select ONE software profile (conda, singularity, docker) and
// optionally combine with an executor profile (slurm, local).
//
// Examples:
//   -profile conda,slurm        Conda envs on SLURM cluster
//   -profile singularity,slurm  Singularity containers on SLURM
//   -profile docker              Docker containers locally
//   -profile conda               Conda envs locally
profiles {
    // --- Executor profiles ---
    slurm {
        includeConfig 'conf/slurm.config'
    }
    local {
        executor.name   = 'local'
        executor.cpus   = params.max_cpus
        executor.memory = params.max_memory
    }

    // --- Software profiles (pick one) ---
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
        conda.useMamba         = true
        conda.createTimeout    = '60 min'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        conda.enabled          = false
        docker.enabled         = false
        singularity.cacheDir   = "${projectDir}/singularity_cache"
    }
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        conda.enabled          = false
        singularity.enabled    = false
    }

    // --- Test profile ---
    test {
        params.sra_query_terms = "HPV16 cervical carcinoma RNA-seq"
        params.max_samples     = 5
        params.outdir          = "${launchDir}/test_results"
    }
}

// Capture execution reports
def timestamp = new java.text.SimpleDateFormat("yyyy-MM-dd_HH-mm-ss").format(new java.util.Date())
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${timestamp}.html"
}
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${timestamp}.txt"
}

// Manifest
manifest {
    name            = 'hpv-human-skin'
    author          = 'Taavi'
    description     = 'HPV type prevalence in human skin and other tissues from public RNA-seq data'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '0.1.0'
}
